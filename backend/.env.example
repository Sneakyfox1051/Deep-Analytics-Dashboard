# Google Sheets API (Service Account)
# 1. Go to https://console.cloud.google.com/
# 2. Create project → Enable "Google Sheets API"
# 3. Create Service Account (IAM → Service Accounts)
# 4. Create key (JSON) and download — do not commit the JSON file
# 5. Share your Google Sheet with the service account email (Viewer)

# Path to service account JSON (relative to backend folder), OR paste the full JSON as a single line
GOOGLE_CREDENTIALS=./credentials.json

# Sheet ID from URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
SPREADSHEET_ID=

# Optional: Sheet range (default Sheet1!A:Z)
SHEET_RANGE=Sheet1!A:Z

# Optional: If set, clients must send X-Api-Key or ?api_key=
API_KEY=

# CORS: your Netlify site URL(s), comma-separated. Use * only for local testing.
# Example: https://your-app.netlify.app
ALLOWED_ORIGINS=*

# Render sets PORT automatically; local default:
PORT=3001
